<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CodexThemeStore.Desktop.RepositorySettingsWindow"
        Title="主题仓库设置"
        Width="480" Height="260"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9F6">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24" RowSpacing="8">
    <TextBlock Text="GitHub 仓库（owner/repository）" Foreground="#30342F" />
    <TextBox x:Name="RepositoryBox" Grid.Row="1" />
    <StackPanel Grid.Row="2" Spacing="7" Margin="0,10,0,0">
      <TextBlock Text="分支" Foreground="#30342F" />
      <TextBox x:Name="BranchBox" Width="220" HorizontalAlignment="Left" />
      <TextBlock x:Name="ValidationLabel" Foreground="#B54432" FontSize="12" />
    </StackPanel>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button x:Name="CancelButton" Content="取消" MinWidth="82" />
      <Button x:Name="SaveButton" Content="保存" MinWidth="82" Background="#D96F4D" Foreground="White" />
    </StackPanel>
  </Grid>
</Window>
