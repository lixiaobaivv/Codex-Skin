<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CodexThemeStore.Desktop.MainWindow"
        Title="Codex-Skin"
        Width="1120" Height="780"
        MinWidth="820" MinHeight="620"
        FontFamily="Inter, PingFang SC, Microsoft YaHei, Noto Sans CJK SC, sans-serif"
        Background="#F5F6F3">
  <Window.Styles>
    <Style Selector="Button.command">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#D96F4D" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="82,*,96">
    <Border Grid.Row="0" Background="#FAFBF8" BorderBrush="#DADDD6" BorderThickness="0,0,0,1" Padding="24,16">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
        <StackPanel VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="Codex-Skin" FontSize="23" FontWeight="SemiBold" Foreground="#20231F" />
          <TextBlock x:Name="CatalogLabel" Text="主题目录" FontSize="12" Foreground="#6D736A" />
        </StackPanel>
        <ComboBox x:Name="CategoryCombo" Grid.Column="1" Width="116" VerticalAlignment="Center" />
        <ComboBox x:Name="SourceCombo" Grid.Column="2" Width="142" VerticalAlignment="Center" />
        <Button x:Name="RefreshButton" Grid.Column="3" Classes="command" Content="刷新" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ListBox x:Name="ThemeList" Background="Transparent" BorderThickness="0" Padding="14">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" ItemWidth="350" ItemHeight="246" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Width="334" Height="230" Margin="8" Background="White" BorderBrush="{Binding BorderBrush}" BorderThickness="{Binding BorderThickness}" CornerRadius="6" ClipToBounds="True">
              <Grid RowDefinitions="174,*">
                <Image Source="{Binding Preview}" Stretch="UniformToFill" />
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="14,9">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#232620" />
                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#70766D" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <Border Grid.Column="1" Background="#F0F2ED" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#596057" />
                  </Border>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <ProgressBar x:Name="BusyBar" IsIndeterminate="True" IsVisible="False" Height="3" VerticalAlignment="Top" />
    </Grid>

    <Border Grid.Row="2" Background="White" BorderBrush="#DADDD6" BorderThickness="0,1,0,0" Padding="24,16">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
        <StackPanel VerticalAlignment="Center" Spacing="3">
          <TextBlock x:Name="SelectionLabel" Text="请选择主题" FontSize="15" FontWeight="SemiBold" Foreground="#252824" />
          <TextBlock x:Name="StatusLabel" Text="准备就绪" FontSize="12" Foreground="#6D736A" TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <Button x:Name="RollbackButton" Grid.Column="1" Classes="command" Content="恢复默认" VerticalAlignment="Center" />
        <Button x:Name="ApplyButton" Grid.Column="2" Classes="command" Content="应用主题" VerticalAlignment="Center" />
        <Button x:Name="RestartButton" Grid.Column="3" Classes="command,primary" Content="应用并重启 Codex" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>
