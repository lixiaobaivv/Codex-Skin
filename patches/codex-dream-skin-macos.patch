+name: macOS Dream Skin importer
+
+on:
+  push:
+    paths:
+      - "macos/**"
+      - ".github/workflows/dreamskin-importer-macos.yml"
+  pull_request:
+    paths:
+      - "macos/**"
+      - ".github/workflows/dreamskin-importer-macos.yml"
+
+permissions:
+  contents: read
+
+jobs:
+  importer:
+    runs-on: macos-14
+    steps:
+      - uses: actions/checkout@v7
+
+      - uses: actions/setup-node@v7
+        with:
+          node-version: 22
+
+      - name: Check launcher syntax
+        run: |
+          bash -n macos/Import\ Dream\ Skin.command
+          bash -n macos/scripts/import-dreamskin-macos.sh
+          bash -n macos/scripts/import-dreamskin-url-macos.sh
+          bash -n macos/scripts/install-dream-skin-macos.sh
+
+      - name: Verify signed package importer on macOS
+        run: node --test macos/tests/dreamskin-import.test.mjs
