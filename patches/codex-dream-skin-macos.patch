@@ -0,0 +1,49 @@
+#!/bin/bash
+
+set -euo pipefail
+. "$(cd "$(dirname "$0")" && pwd -P)/common-macos.sh"
+
+PACKAGE=""
+APPLY_NOW="false"
+while [ "$#" -gt 0 ]; do
+  case "$1" in
+    --file) PACKAGE="${2:-}"; shift 2 ;;
+    --apply) APPLY_NOW="true"; shift ;;
+    *) fail "Unknown Dream Skin import argument: $1" ;;
+  esac
+done
+
+[ -n "$PACKAGE" ] || fail "Usage: import-dreamskin-macos.sh --file <theme.dreamskin> [--apply]"
+[ -f "$PACKAGE" ] || fail "Dream Skin package not found."
+
+if ! /usr/bin/osascript <<APPLESCRIPT
+display dialog "Verify and install this Dream Skin package?\n\n$(/usr/bin/basename "$PACKAGE")" with title "Codex Dream Skin" buttons {"Cancel", "Verify and Install"} default button "Verify and Install" cancel button "Cancel" with icon caution
+APPLESCRIPT
+then
+  exit 0
+fi
+
+ensure_state_root
+ensure_node_runtime
+THEMES_ROOT="$STATE_ROOT/themes"
+/bin/mkdir -p "$THEMES_ROOT"
+/bin/chmod 700 "$THEMES_ROOT"
+
+RESULT="$("$NODE" "$SCRIPT_DIR/import-dreamskin.mjs" \
+  --file "$PACKAGE" \
+  --library-root "$THEMES_ROOT")" || fail "Dream Skin package validation or installation failed."
+
+THEME_ID="$("$NODE" -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.id)' "$RESULT")"
+THEME_VERSION="$("$NODE" -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.version)' "$RESULT")"
+THEME_NAME="$("$NODE" -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.name)' "$RESULT")"
+PACKAGE_HASH="$("$NODE" -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.packageSha256)' "$RESULT")"
+
+printf 'Installed verified Dream Skin theme: %s (%s %s)\n' "$THEME_NAME" "$THEME_ID" "$THEME_VERSION"
+printf 'Package SHA-256: %s\n' "$PACKAGE_HASH"
+/usr/bin/osascript -e "display notification \"Installed ${THEME_NAME}\" with title \"Codex Dream Skin\"" >/dev/null 2>&1 || true
+
+if [ "$APPLY_NOW" = "true" ]; then
+  exec "$SCRIPT_DIR/switch-theme-macos.sh" --id "$THEME_ID"
+fi
+
+printf 'The theme is installed but not applied. Re-run with --apply after reviewing it.\n'
