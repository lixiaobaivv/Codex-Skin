+++ b/macos/assets/dreamskin-handler.applescript
@@ -0,0 +1,21 @@
+on engineScript(relativePath)
+	set homePath to POSIX path of (path to home folder)
+	return homePath & ".codex/codex-dream-skin-studio/scripts/" & relativePath
+end engineScript
+
+on open location installURL
+	set importer to engineScript("import-dreamskin-url-macos.sh")
+	do shell script quoted form of importer & " --uri " & quoted form of installURL
+end open location
+
+on open droppedItems
+	set importer to engineScript("import-dreamskin-macos.sh")
+	repeat with droppedItem in droppedItems
+		do shell script quoted form of importer & " --file " & quoted form of POSIX path of droppedItem
+	end repeat
+end open
+
+on run
+	set selectedPackage to choose file with prompt "Choose a signed .dreamskin theme package"
+	open {selectedPackage}
+end run
