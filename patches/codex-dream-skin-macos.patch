+#!/bin/bash
+
+set -euo pipefail
+. "$(cd "$(dirname "$0")" && pwd -P)/common-macos.sh"
+
+URI=""
+while [ "$#" -gt 0 ]; do
+  case "$1" in
+    --uri) URI="${2:-}"; shift 2 ;;
+    *) fail "Unknown Dream Skin URL import argument: $1" ;;
+  esac
+done
+[ -n "$URI" ] || fail "Usage: import-dreamskin-url-macos.sh --uri <dreamskin://install?...>"
+
+ensure_state_root
+ensure_node_runtime
+REQUEST="$($NODE "$SCRIPT_DIR/import-dreamskin-url.mjs" --uri "$URI" --inspect)" || fail "The Dream Skin install link is invalid."
+HOST="$($NODE -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.host)' "$REQUEST")"
+SIZE="$($NODE -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(String(r.size))' "$REQUEST")"
+THEME_HINT="$($NODE -e 'const r=JSON.parse(process.argv[1]);process.stdout.write([r.id,r.version].filter(Boolean).join(" "))' "$REQUEST")"
+
+if ! /usr/bin/osascript <<APPLESCRIPT
+display dialog "Download and verify this signed Dream Skin theme?\n\nTheme: ${THEME_HINT:-not specified}\nSource: $HOST\nSize: $SIZE bytes" with title "Codex Dream Skin" buttons {"Cancel", "Download and Install"} default button "Download and Install" cancel button "Cancel" with icon caution
+APPLESCRIPT
+then
+  exit 0
+fi
+
+THEMES_ROOT="$STATE_ROOT/themes"
+/bin/mkdir -p "$THEMES_ROOT"
+/bin/chmod 700 "$THEMES_ROOT"
+RESULT="$($NODE "$SCRIPT_DIR/import-dreamskin-url.mjs" --uri "$URI" --state-root "$STATE_ROOT" --library-root "$THEMES_ROOT")" || fail "Download, signature validation, or installation failed."
+THEME_ID="$($NODE -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.id)' "$RESULT")"
+THEME_NAME="$($NODE -e 'const r=JSON.parse(process.argv[1]);process.stdout.write(r.name)' "$RESULT")"
+
+if /usr/bin/osascript <<APPLESCRIPT
+display dialog "Installed and verified ${THEME_NAME}.\n\nApply it to Codex now?" with title "Codex Dream Skin" buttons {"Not Now", "Apply"} default button "Not Now"
+APPLESCRIPT
+then
+  exec "$SCRIPT_DIR/switch-theme-macos.sh" --id "$THEME_ID"
+fi
+printf 'Installed %s but did not apply it.\n' "$THEME_NAME"
diff --git a/macos/scripts/import-dreamskin-url.mjs b/macos/scripts/import-dreamskin-url.mjs
new file mode 100644
index 0000000..0f740f4
--- /dev/null
+++ b/macos/scripts/import-dreamskin-url.mjs
@@ -0,0 +1,262 @@
+#!/usr/bin/env node
+
+import dns from "node:dns";
+import { createHash, randomUUID } from "node:crypto";
+import fsp from "node:fs/promises";
+import https from "node:https";
+import net from "node:net";
+import path from "node:path";
+import { fileURLToPath } from "node:url";
+import { installDreamSkinPackage } from "./import-dreamskin.mjs";
+
+const MAX_URI_BYTES = 4096;
+const MAX_PACKAGE_BYTES = 20 * 1024 * 1024;
+const MAX_REDIRECTS = 3;
+const allowedParameters = new Set(["url", "sha256", "size", "id", "version"]);
+const hashPattern = /^[a-f0-9]{64}$/;
+const themeIdPattern = /^[a-z0-9]+(?:[.-][a-z0-9]+)*$/;
+const semverPattern = /^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\.[0-9A-Za-z-]+)*)?(?:\+[0-9A-Za-z-]+(?:\.[0-9A-Za-z-]+)*)?$/;
+
+export function parseInstallUri(input) {
+  if (typeof input !== "string" || input.length === 0 || Buffer.byteLength(input, "utf8") > MAX_URI_BYTES) fail("DSI_URI_INVALID", "dreamskin URI is empty or exceeds 4096 bytes.");
+  let uri;
+  try { uri = new URL(input); } catch { fail("DSI_URI_INVALID", "Invalid dreamskin URI."); }
+  if (uri.protocol !== "dreamskin:" || uri.hostname.toLowerCase() !== "install" || uri.username || uri.password || uri.hash || (uri.pathname && uri.pathname !== "/")) fail("DSI_URI_INVALID", "Only dreamskin://install is accepted.");
+  const queryIndex = input.indexOf("?");
+  if (queryIndex < 0 || queryIndex === input.length - 1) fail("DSI_URI_INVALID", "Import URI has no query parameters.");
+  const rawQuery = input.slice(queryIndex + 1);
+  if (rawQuery.includes("#")) fail("DSI_URI_INVALID", "Fragments are not allowed.");
+  const values = new Map();
+  for (const pair of rawQuery.split("&")) {
+    if (!pair) fail("DSI_URI_INVALID", "Empty query parameter.");
+    const separator = pair.indexOf("=");
+    if (separator <= 0 || pair.indexOf("=", separator + 1) >= 0) fail("DSI_URI_INVALID", "Each query parameter must contain one equals sign.");
+    const rawName = pair.slice(0, separator);
+    const rawValue = pair.slice(separator + 1);
+    const name = decodePercentOnce(rawName);
+    if (!allowedParameters.has(name)) fail("DSI_URI_INVALID", `Unknown query parameter: ${name}`);
+    if (values.has(name)) fail("DSI_URI_INVALID", `Duplicate query parameter: ${name}`);
+    if (name === "url" && /[:/]/.test(rawValue)) fail("DSI_URI_INVALID", "url must be fully percent encoded.");
+    values.set(name, decodePercentOnce(rawValue));
+  }
+  for (const required of ["url", "sha256", "size"]) if (!values.get(required)) fail("DSI_URI_INVALID", `Missing query parameter: ${required}`);
+  const packageUrl = validatePackageUrl(values.get("url"));
+  const sha256 = values.get("sha256");
+  if (!hashPattern.test(sha256)) fail("DSI_URI_INVALID", "sha256 must be 64 lowercase hexadecimal characters.");
+  if (!/^[0-9]+$/.test(values.get("size"))) fail("DSI_URI_INVALID", "size must be decimal bytes.");
+  const size = Number(values.get("size"));
+  if (!Number.isSafeInteger(size) || size < 1 || size > MAX_PACKAGE_BYTES) fail("DSI_URI_INVALID", "size is outside the 1 to 20971520 byte range.");
+  const id = values.get("id");
+  if (id !== undefined && (id.length < 3 || id.length > 128 || !themeIdPattern.test(id))) fail("DSI_URI_INVALID", "Invalid id hint.");
+  const version = values.get("version");
+  if (version !== undefined && (version.length > 64 || !semverPattern.test(version))) fail("DSI_URI_INVALID", "Invalid version hint.");
+  return { packageUrl: packageUrl.href, host: packageUrl.hostname, sha256, size, id, version };
+}
+
+export async function downloadAndInstall(request, options = {}) {
+  const stateRoot = path.resolve(options.stateRoot ?? path.join(process.env.HOME ?? "", "Library", "Application Support", "CodexDreamSkinStudio"));
+  const downloadRoot = safeChild(stateRoot, "downloads", randomUUID());
+  const archivePath = path.join(downloadRoot, "archive.dreamskin");
+  await fsp.mkdir(downloadRoot, { recursive: true, mode: 0o700 });
+  try {
+    const downloaded = await downloadPackage(new URL(request.packageUrl), request);
+    await fsp.writeFile(archivePath, downloaded, { mode: 0o600, flag: "wx" });
+    await fsp.chmod(archivePath, 0o600);
+    return await installDreamSkinPackage(archivePath, {
+      libraryRoot: options.libraryRoot ?? path.join(stateRoot, "themes"),
+      expectedSha256: request.sha256,
+      expectedSize: request.size,
+      expectedId: request.id,
+      expectedVersion: request.version,
+      keyringPath: options.keyringPath,
+      allowNonDarwinInstall: options.allowNonDarwinInstall,
+      skipAlias: options.skipAlias,
+    });
+  } finally {
+    await fsp.rm(downloadRoot, { recursive: true, force: true }).catch(() => {});
+  }
+}
+
+async function downloadPackage(initial, expected) {
+  let current = validatePackageUrl(initial.href);
+  for (let redirects = 0; ; redirects += 1) {
+    const response = await requestOnce(current);
+    if ([301, 302, 303, 307, 308].includes(response.statusCode)) {
+      response.resume();
+      if (redirects >= MAX_REDIRECTS) fail("DSI_REDIRECT_LIMIT", "Package download exceeded three redirects.");
+      const location = response.headers.location;
+      if (!location) fail("DSI_DOWNLOAD_FAILED", "Redirect has no Location header.");
+      current = validatePackageUrl(new URL(location, current).href);
+      continue;
+    }
+    if (response.statusCode < 200 || response.statusCode > 299) { response.resume(); fail("DSI_DOWNLOAD_FAILED", `Package server returned HTTP ${response.statusCode}.`); }
+    const contentLength = response.headers["content-length"];
+    if (contentLength !== undefined) {
+      if (!/^[0-9]+$/.test(contentLength)) { response.resume(); fail("DSI_SIZE_LIMIT", "Invalid Content-Length header."); }
+      const length = Number(contentLength);
+      if (length < 1 || length > MAX_PACKAGE_BYTES || length !== expected.size) { response.resume(); fail("DSI_SIZE_MISMATCH", "Content-Length differs from the import request."); }
+    }
+    return await readBoundedResponse(response, expected);
+  }
+}
+
+function requestOnce(url) {
+  return new Promise((resolve, reject) => {
+    const request = https.request(url, {
+      method: "GET",
+      agent: false,
+      headers: { Accept: "application/vnd.codex-dream-skin+zip", "User-Agent": "CodexDreamSkinStudio/1.1.1" },
+      lookup: publicLookup,
+      timeout: 15000,
+    }, resolve);
+    request.once("timeout", () => request.destroy(error("DSI_DOWNLOAD_FAILED", "Package connection timed out.")));
+    request.once("error", (cause) => reject(cause.code?.startsWith?.("DSI_") ? cause : error("DSI_DOWNLOAD_FAILED", "Package request failed.")));
+    request.end();
+  });
+}
+
+function readBoundedResponse(response, expected) {
+  return new Promise((resolve, reject) => {
+    const chunks = [];
+    const hash = createHash("sha256");
+    let total = 0;
+    response.on("data", (chunk) => {
+      total += chunk.length;
+      if (total > MAX_PACKAGE_BYTES || total > expected.size) {
+        response.destroy(error("DSI_SIZE_LIMIT", "Package body exceeds declared size or 20 MiB."));
+        return;
+      }
+      hash.update(chunk);
+      chunks.push(chunk);
+    });
+    response.once("error", reject);
+    response.once("end", () => {
+      if (total !== expected.size) return reject(error("DSI_SIZE_MISMATCH", "Downloaded byte count differs from the import request."));
+      if (hash.digest("hex") !== expected.sha256) return reject(error("DSI_HASH_MISMATCH", "Downloaded package SHA-256 differs from the import request."));
+      resolve(Buffer.concat(chunks, total));
+    });
+  });
+}
+
+function publicLookup(hostname, options, callback) {
+  dns.lookup(hostname, { all: true, verbatim: true }, (cause, addresses) => {
+    if (cause) return callback(error("DSI_DOWNLOAD_FAILED", "Package host DNS lookup failed."));
+    const allowed = addresses.filter((entry) => isPublicAddress(entry.address));
+    if (allowed.length === 0) return callback(error("DSI_NETWORK_BLOCKED", "Package host did not resolve to a public address."));
+    const selected = options?.family ? allowed.find((entry) => entry.family === options.family) : allowed[0];
+    if (!selected) return callback(error("DSI_NETWORK_BLOCKED", "Package host has no public address in the requested family."));
+    if (options?.all) callback(null, allowed); else callback(null, selected.address, selected.family);
+  });
+}
+
+function validatePackageUrl(value) {
+  let url;
+  try { url = new URL(value); } catch { fail("DSI_URI_INVALID", "Package URL is invalid."); }
+  if (url.protocol !== "https:" || url.username || url.password || url.hash || (url.port && url.port !== "443") || !url.hostname) fail("DSI_URI_INVALID", "Package URL must be credential-free HTTPS on port 443.");
+  const host = url.hostname.toLowerCase();
+  if (host === "localhost" || host.endsWith(".localhost") || host.endsWith(".local")) fail("DSI_NETWORK_BLOCKED", "Local package hosts are not allowed.");
+  if (net.isIP(host) && !isPublicAddress(host)) fail("DSI_NETWORK_BLOCKED", "Private, link-local and reserved package addresses are not allowed.");
+  return url;
+}
+
+export function isPublicAddress(address) {
+  const family = net.isIP(address);
+  if (family === 4) return isPublicIpv4(address.split(".").map(Number));
+  if (family !== 6) return false;
+  const bytes = ipv6Bytes(address);
+  if (!bytes) return false;
+  if (bytes.subarray(0, 10).every((value) => value === 0) && bytes[10] === 0xff && bytes[11] === 0xff) return isPublicIpv4([...bytes.subarray(12)]);
+  if (bytes.every((value) => value === 0) || (bytes.subarray(0, 15).every((value) => value === 0) && bytes[15] === 1)) return false;
+  if ((bytes[0] & 0xfe) === 0xfc || (bytes[0] === 0xfe && (bytes[1] & 0xc0) === 0x80) || bytes[0] === 0xff) return false;
+  if (bytes[0] === 0x20 && bytes[1] === 0x02) return false;
+  if (bytes[0] === 0x20 && bytes[1] === 0x01 && bytes[2] === 0 && bytes[3] === 0) return false;
+  if (bytes[0] === 0x20 && bytes[1] === 0x01 && bytes[2] === 0x0d && bytes[3] === 0xb8) return false;
+  if (bytes.subarray(0, 12).equals(Buffer.from([0, 0x64, 0xff, 0x9b, 0, 0, 0, 0, 0, 0, 0, 0]))) return false;
+  if (bytes.subarray(0, 12).every((value) => value === 0)) return false;
+  return true;
+}
+
+function isPublicIpv4(bytes) {
+  const [a, b, c] = bytes;
+  if (bytes.length !== 4 || bytes.some((value) => !Number.isInteger(value) || value < 0 || value > 255)) return false;
+  if (a === 0 || a === 10 || a === 127 || a >= 224) return false;
+  if (a === 100 && b >= 64 && b <= 127) return false;
+  if (a === 169 && b === 254) return false;
+  if (a === 172 && b >= 16 && b <= 31) return false;
+  if (a === 192 && (b === 0 || b === 168)) return false;
+  if (a === 192 && b === 88 && c === 99) return false;
+  if (a === 198 && (b === 18 || b === 19)) return false;
+  if (a === 198 && b === 51 && c === 100) return false;
+  if (a === 203 && b === 0 && c === 113) return false;
+  return true;
+}
+
+function ipv6Bytes(input) {
+  let address = input.split("%")[0].toLowerCase();
+  if (address.includes(".")) {
+    const lastColon = address.lastIndexOf(":");
+    const ipv4 = address.slice(lastColon + 1).split(".").map(Number);
+    if (!isValidIpv4(ipv4)) return null;
+    address = `${address.slice(0, lastColon)}:${((ipv4[0] << 8) | ipv4[1]).toString(16)}:${((ipv4[2] << 8) | ipv4[3]).toString(16)}`;
+  }
+  const halves = address.split("::");
+  if (halves.length > 2) return null;
+  const left = halves[0] ? halves[0].split(":") : [];
+  const right = halves[1] ? halves[1].split(":") : [];
+  const fill = halves.length === 2 ? 8 - left.length - right.length : 0;
+  if ((halves.length === 1 && left.length !== 8) || fill < 1) return null;
+  const groups = [...left, ...Array(fill).fill("0"), ...right];
+  if (groups.length !== 8 || groups.some((group) => !/^[0-9a-f]{1,4}$/.test(group))) return null;
+  const bytes = Buffer.alloc(16);
+  groups.forEach((group, index) => bytes.writeUInt16BE(Number.parseInt(group, 16), index * 2));
+  return bytes;
+}
+
