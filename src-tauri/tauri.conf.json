{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex-Skin",
  "version": "0.6.1",
  "identifier": "com.codexskin.themestore",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "Codex-Skin",
      "width": 1120,
      "height": 780,
      "minWidth": 820,
      "minHeight": 620,
      "resizable": true,
      "center": true
    }],
    "security": { "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost" }
  },
  "plugins": {
    "deep-link": { "desktop": { "schemes": ["dreamskin"] } }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "fileAssociations": [{ "ext": ["dreamskin"], "name": "Codex Dream Skin Theme Package", "description": "Signed Codex-Skin theme package" }]
  }
}
